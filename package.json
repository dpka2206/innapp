{
  "name": "socialmediacalander",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,mobile -c green,cyan \"npm run dev -w @smc/api\" \"npm run start -w @smc/mobile\"",
    "dev:api": "npm run dev -w @smc/api",
    "dev:mobile": "npm run start -w @smc/mobile",
    "web": "npm run web -w @smc/mobile",
    "seed": "npm run seed -w @smc/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
